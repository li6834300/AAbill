# server 运行所需环境变量(值不入库,Heroku 用 config vars 配置)
DATABASE_URL=            # Neon Postgres 连接串
OPENAI_API_KEY=          # 发票识别(月上限 $10,在 OpenAI 后台设硬限额)
CLOUDINARY_URL=          # 发票图片存储
JWT_SECRET=              # Owner 会话签名
# 本地测试库(Docker):postgres://localhost:5432/aabill_test
AI_PROVIDER=              # mock(默认,无 key 时)| openai
OPENAI_MODEL=             # 默认 gpt-4o
EXPO_PUBLIC_API_URL=      # 客户端 API 地址,默认 http://localhost:3000
