{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "server",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "-w",
        "server"
      ],
      "port": 3000,
      "env": {
        "ALLOW_DEV_LOGIN": "1",
        "AI_PROVIDER": "mock"
      }
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "web",
        "-w",
        "apps/mobile"
      ],
      "port": 8081
    }
  ]
}
